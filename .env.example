# Appwrite Configuration
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_project_id_here
VITE_APPWRITE_DATABASE_ID=your_database_id_here
VITE_APPWRITE_TASKS_COLLECTION_ID=tasks

# Server-side API key (for setup scripts only — NOT exposed to browser)
# Create in Appwrite Console > Overview > API Keys > Create API Key
# Required scopes: databases.read, databases.write, collections.read, collections.write
APPWRITE_API_KEY=your_api_key_here

# AI Features (Google Gemini)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Notification Services (when implemented)
# TWILIO_ACCOUNT_SID=your_twilio_sid_here
# TWILIO_AUTH_TOKEN=your_twilio_token_here
# TWILIO_WHATSAPP_NUMBER=your_whatsapp_number_here
# DISCORD_BOT_TOKEN=your_discord_token_here
