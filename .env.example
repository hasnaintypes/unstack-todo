# =============================================================================
#  UNSTACK-TODO — Environment Variables
#
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git — it contains secrets.
# =============================================================================


# =============================================================================
#  APPWRITE — Frontend (exposed to browser via VITE_ prefix)
# =============================================================================

# Appwrite API endpoint (e.g. https://cloud.appwrite.io/v1 or self-hosted)
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# Appwrite project ID (found in Console > Settings)
VITE_APPWRITE_PROJECT_ID=

# Appwrite database ID (auto-created by pnpm setup:db if left blank)
VITE_APPWRITE_DATABASE_ID=

# Appwrite storage bucket ID for file uploads (avatars, task attachments)
# Default: "uploads" — create this bucket in Console > Storage
VITE_APPWRITE_BUCKET_ID=uploads


# =============================================================================
#  APPWRITE — Collection IDs (created by: pnpm setup:db)
#  Defaults match the IDs in setup-db.mjs. Only override if you used custom IDs.
# =============================================================================

VITE_APPWRITE_TASKS_COLLECTION_ID=tasks
VITE_APPWRITE_PROJECTS_COLLECTION_ID=projects
VITE_APPWRITE_CATEGORIES_COLLECTION_ID=categories
VITE_APPWRITE_PROFILES_COLLECTION_ID=profiles
VITE_APPWRITE_SUBTASKS_COLLECTION_ID=subtasks
VITE_APPWRITE_PREFERENCES_COLLECTION_ID=user_preferences
VITE_APPWRITE_TASK_COMMENTS_COLLECTION_ID=task_comments
VITE_APPWRITE_TASK_TEMPLATES_COLLECTION_ID=task_templates


# =============================================================================
#  APPWRITE — Server-side API Key (NOT exposed to browser — no VITE_ prefix)
#  Used by: scripts/setup-db.mjs, scripts/test-email.mjs, Inngest functions
#  Create in: Appwrite Console > Overview > API Keys
#  Required scopes: databases, collections, documents, users, messaging
# =============================================================================

APPWRITE_API_KEY=


# =============================================================================
#  AI Features — Google Gemini (server-side only, via Vercel API proxy)
#  Used by: api/ai.ts (Vercel serverless function)
#  Get API key: https://aistudio.google.com/apikey
#  Set in: Vercel Dashboard > Project > Settings > Environment Variables
# =============================================================================

GEMINI_API_KEY=


# =============================================================================
#  INNGEST — Serverless Cron Functions (Vercel deployment)
#
#  Inngest powers the check-reminders (every 15 min) and daily-summary
#  (every hour) cron functions. These run as Vercel serverless functions
#  via the /api/inngest endpoint.
#
#  Set these in Vercel Dashboard > Project > Settings > Environment Variables
#  (NOT in the browser — these are server-side only)
# =============================================================================

# Inngest signing key — authenticates incoming requests from Inngest
# Get from: https://app.inngest.com > Project > Manage > Signing Key
# Required in production. In dev, inngest dev server works without it.
INNGEST_SIGNING_KEY=

# Inngest event key — used to send events to Inngest (optional for cron-only)
# Get from: https://app.inngest.com > Project > Manage > Event Keys
INNGEST_EVENT_KEY=


# =============================================================================
#  INNGEST FUNCTIONS — Appwrite server-side config
#
#  These are read by api/inngest/functions/*.ts at runtime on Vercel.
#  Set in Vercel Dashboard > Project > Settings > Environment Variables.
#  Note: These do NOT use the VITE_ prefix (server-side only).
# =============================================================================

# Appwrite endpoint (defaults to https://cloud.appwrite.io/v1 if not set)
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# Appwrite project ID (same as VITE_APPWRITE_PROJECT_ID but for server)
APPWRITE_PROJECT_ID=

# Appwrite database ID (same as VITE_APPWRITE_DATABASE_ID but for server)
APPWRITE_DATABASE_ID=

# Collection IDs for Inngest functions (defaults shown)
TASKS_COLLECTION_ID=tasks
PREFERENCES_COLLECTION_ID=user_preferences


# =============================================================================
#  DISCORD INTEGRATION — Notifications via Discord (optional)
#
#  Used by: api/inngest/functions/check-reminders.ts (webhook)
#           appwrite-functions/discord-oauth/ (OAuth2 flow)
#
#  For the discord-oauth Appwrite Function, set these as environment
#  variables in Appwrite Console > Functions > discord-oauth > Settings.
# =============================================================================

# Discord bot token for sending DM reminders to users
# Get from: Discord Developer Portal > your bot > Bot tab > Token
DISCORD_BOT_TOKEN=

# Discord OAuth2 app credentials (for discord-oauth Appwrite Function only)
# Create at: https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=

# Frontend URL for OAuth redirect callbacks
# Default: http://localhost:5173 (dev) — change to your production URL
APP_URL=http://localhost:5173
