# ============================================================
# Appwrite Configuration (exposed to browser via VITE_ prefix)
# ============================================================
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_project_id_here
VITE_APPWRITE_DATABASE_ID=your_database_id_here
VITE_APPWRITE_BUCKET_ID=your_bucket_id_here

# Collection IDs (created by: pnpm setup:db)
VITE_APPWRITE_TASKS_COLLECTION_ID=tasks
VITE_APPWRITE_PROJECTS_COLLECTION_ID=projects
VITE_APPWRITE_CATEGORIES_COLLECTION_ID=categories
VITE_APPWRITE_PROFILES_COLLECTION_ID=profiles
VITE_APPWRITE_SUBTASKS_COLLECTION_ID=subtasks
VITE_APPWRITE_PREFERENCES_COLLECTION_ID=user_preferences

# ============================================================
# Server-side API Key (for setup scripts + Appwrite Functions)
# NOT exposed to browser — no VITE_ prefix
# Create in: Appwrite Console > Overview > API Keys
# Required scopes: databases, collections, documents, users
# ============================================================
APPWRITE_API_KEY=your_api_key_here

# ============================================================
# AI Features (Google Gemini)
# ============================================================
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# Appwrite Functions — Reminders (server-side only)
# These are set as environment variables in each Appwrite Function
# via the Appwrite Console, NOT in this .env file.
# Listed here for reference only.
# ============================================================
# APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
# APPWRITE_PROJECT_ID=your_project_id
# APPWRITE_API_KEY=your_api_key
# APPWRITE_DATABASE_ID=your_database_id
# TASKS_COLLECTION_ID=tasks
# PREFERENCES_COLLECTION_ID=user_preferences

# ============================================================
# Discord Integration (for discord-oauth Appwrite Function)
# ============================================================
# DISCORD_CLIENT_ID=your_discord_app_client_id
# DISCORD_CLIENT_SECRET=your_discord_app_client_secret
# DISCORD_REDIRECT_URI=https://your-appwrite-endpoint/v1/functions/discord-oauth/callback
# DISCORD_BOT_WEBHOOK_URL=https://your-discord-bot-webhook-url
